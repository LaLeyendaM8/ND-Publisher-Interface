APP_ENV=production
APP_INTERNAL_API_TOKEN=change-me
APP_STORAGE_ROOT=/app/data
OPENAI_API_KEY=sk-...
DATABASE_URL=postgresql://postgres:<PASSWORD>@<HOST>:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-if-needed>
